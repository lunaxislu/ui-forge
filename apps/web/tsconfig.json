{
    "extends": "@workspace/typescript-config/nextjs.json",
    "compilerOptions": {
        "baseUrl": ".",
        "paths": {
            "@/*": ["./*"],
            "@workspace/radix-ui/*": ["../../packages/radix-ui/src/*"],
            "@workspace/base-ui/*": ["../../packages/base-ui/src/*"],
            "@workspace/ui-shared/*": ["../../packages/ui-shared/src/*"]
        },
        "plugins": [
            {
                "name": "next"
            }
        ]
    },
    "include": [
        "next-env.d.ts",
        "**/*.ts",
        "**/*.tsx",
        ".next/types/**/*.ts"
    ],
    "exclude": ["node_modules"]
}
